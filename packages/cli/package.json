{
  "name": "@oboe/cli",
  "version": "0.1.0",
  "type": "module",
  "bin": {
    "oboe": "./dist/cli.js"
  },
  "main": "./dist/cli.js",
  "types": "./dist/cli.d.ts",
  "dependencies": {
    "@oboe/core": "workspace:*",
    "@oboe/db-mysql": "workspace:*",
    "@oboe/db-postgres": "workspace:*",
    "@oboe/db-sqlite": "workspace:*",
    "@oboe/storage-relational": "workspace:*",
    "better-sqlite3": "^11.10.0",
    "mysql2": "^3.15.3",
    "pg": "^8.20.0",
    "tsx": "^4.21.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch --preserveWatchOutput",
    "lint": "tsc -p tsconfig.json --noEmit",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  }
