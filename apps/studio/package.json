{
  "name": "@oboe/studio",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "pnpm generate:types && next build",
    "dev": "pnpm generate:types && next dev",
    "generate:types": "node ../../packages/cli/dist/cli.js generate:types --config ./oboe.config.ts",
    "lint": "pnpm generate:types && tsc -p tsconfig.json --noEmit",
    "typecheck": "pnpm generate:types && tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@oboe/admin-next": "workspace:*",
    "@oboe/core": "workspace:*",
    "@oboe/db-postgres": "workspace:*",
    "@oboe/graphql": "workspace:*",
    "@oboe/http": "workspace:*",
    "@oboe/jobs": "workspace:*",
    "@oboe/storage-azure-blob": "workspace:*",
    "@oboe/storage-gcs": "workspace:*",
    "@oboe/storage-r2": "workspace:*",
    "@oboe/storage-s3": "workspace:*",
    "@oboe/storage-vercel-blob": "workspace:*",
    "next": "^16.2.2",
    "pg": "^8.13.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@oboe/cli": "workspace:*",
    "@oboe/typescript-plugin": "workspace:*"
  }
}
