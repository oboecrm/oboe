{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "allowJs": true,
    "baseUrl": ".",
    "incremental": true,
    "jsx": "preserve",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noEmit": true,
    "paths": {
      "@oboe/admin-next": ["../../packages/admin-next/src/index.tsx"],
      "@oboe/core": ["../../packages/core/dist/index.js"],
      "@oboe/core/testing": ["../../packages/core/dist/testing/index.js"],
      "@oboe/db-postgres": ["../../packages/db-postgres/dist/index.js"],
      "@oboe/graphql": ["../../packages/graphql/src/index.ts"],
      "@oboe/http": ["../../packages/http/src/index.ts"],
      "@oboe/jobs": ["../../packages/jobs/src/index.ts"]
    },
    "plugins": [
      {
        "name": "next"
      }
    ]
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
  "exclude": ["node_modules"]
}
