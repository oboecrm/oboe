{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "allowJs": true,
    "baseUrl": ".",
    "incremental": true,
    "jsx": "preserve",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noEmit": true,
    "paths": {
      "@oboe/admin-next": ["../../packages/admin-next/src/index.tsx"],
      "@oboe/storage-azure-blob": [
        "../../packages/storage-azure-blob/dist/index.js"
      ],
      "@oboe/storage-gcs": ["../../packages/storage-gcs/dist/index.js"],
      "@oboe/storage-r2": ["../../packages/storage-r2/dist/index.js"],
      "@oboe/storage-s3": ["../../packages/storage-s3/dist/index.js"],
      "@oboe/storage-vercel-blob": [
        "../../packages/storage-vercel-blob/dist/index.js"
      ],
      "@oboe/core": ["../../packages/core/dist/index.js"],
      "@oboe/core/testing": ["../../packages/core/dist/testing/index.js"],
      "@oboe/db-postgres": ["../../packages/db-postgres/dist/index.js"],
      "@oboe/graphql": ["../../packages/graphql/src/index.ts"],
      "@oboe/http": ["../../packages/http/src/index.ts"],
      "@oboe/jobs": ["../../packages/jobs/src/index.ts"]
    },
    "plugins": [
      {
        "name": "next"
      },
      {
        "name": "@oboe/typescript-plugin"
      }
    ]
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
  "exclude": ["node_modules"]
}
